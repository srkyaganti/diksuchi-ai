# Diksuchi-AI Platform Environment Configuration

# ============================================================================
# DATABASE
# ============================================================================
DATABASE_URL=postgresql://postgres:password@localhost:5432/diksuchi?schema=public

# ============================================================================
# REDIS (Job Queue & Caching)
# ============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379

# ============================================================================
# NEXT.JS WEB APPLICATION (services/web)
# ============================================================================
# Better Auth
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=your-secret-key-minimum-32-characters-required-here
BETTER_AUTH_URL=http://localhost:3000

# Internal API Secret (shared with RAG service)
INTERNAL_API_SECRET=changeme-in-production

# ============================================================================
# RAG SERVICE (services/rag-service)
# ============================================================================
# Service URLs (for Next.js to call RAG service)
PYTHON_WORKER_URL=http://localhost:5001
PYTHON_RETRIEVAL_URL=http://localhost:5001

# ChromaDB (Vector Database)
CHROMADB_HOST=localhost
CHROMADB_PORT=8000

# Ollama (Local LLM - optional)
OLLAMA_BASE_URL=http://localhost:11434

# Embedding Model
EMBEDDING_MODEL_PATH=models/bge-m3.gguf

# LlamaParse API (optional - for advanced PDF parsing)
LLAMAPARSE_API_KEY=

# ============================================================================
# STT SERVICE - Speech-to-Text (whisper.cpp)
# ============================================================================
# whisper.cpp must be started separately before using transcription
# Default whisper.cpp server port is 8080
STT_SERVICE_URL=http://localhost:8080
WHISPER_API_URL=http://localhost:8080
STT_MAX_AUDIO_SIZE_MB=25

# ============================================================================
# TTS SERVICE (services/tts-service) - Text-to-Speech
# ============================================================================
TTS_SERVICE_URL=http://localhost:8002
TTS_DEFAULT_LANGUAGE=hi

# ============================================================================
# LLM SERVICE - LM Studio (External)
# ============================================================================
# LM Studio provides local LLM inference with OpenAI-compatible API
# Default LM Studio port: 1234
LLM_SERVICE_BASE_URL=http://localhost:1234/v1
LLM_MODEL=llama-3.2-3b-instruct  # Configure this in LM Studio

# ============================================================================
# HUGGING FACE (for STT/TTS models)
# ============================================================================
HF_TOKEN=your_huggingface_token_here

# ============================================================================
# NOTES
# ============================================================================
# - For Docker deployments, service URLs use container names (e.g., http://rag-service:5000)
# - For local development, use localhost URLs as shown above
# - Generate BETTER_AUTH_SECRET with: openssl rand -base64 32
# - HF_TOKEN required for downloading Whisper and ParlerTTS models
# - Minimum 16GB RAM recommended for running all services
