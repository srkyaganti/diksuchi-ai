# ============================================================
# DIKSUCHI-AI PLATFORM - DOCKER ENVIRONMENT CONFIGURATION
# ============================================================
#
# Copy this file to .env and fill in the values
# Generate secrets with: openssl rand -base64 32
#
# ============================================================

# ============== SHARED SECRETS ==============

# HuggingFace token for downloading gated models
HF_TOKEN=your_huggingface_token_here

# Internal API secret for service-to-service communication
INTERNAL_API_SECRET=your-internal-api-secret-minimum-32-characters

# ============== DATABASE ==============

DB_USER=postgres
DB_PASSWORD=your_secure_password_here

# ============== WEB APP (services/web) ==============

# Better Auth secret for session encryption
BETTER_AUTH_SECRET=your-better-auth-secret-minimum-32-characters

# Public URL for the web app
BETTER_AUTH_URL=http://localhost:3000

# ============== RAG SERVICE (services/rag-service) ==============

# Embedding model name (must be available in Ollama)
RAG_EMBEDDING_MODEL=bge-m3

# Ollama URL (use host.docker.internal for Docker on Mac/Windows)
RAG_OLLAMA_URL=http://host.docker.internal:11434

# ============== VOICE SERVICE (services/voice-service) ==============

# STT Configuration
# Whisper model: tiny, base, small, medium, large-v2, large-v3, distil-large-v3, turbo
STT_MODEL_NAME=large-v3
STT_DEVICE=cuda
STT_COMPUTE_TYPE=float16
STT_VAD_FILTER=true

# TTS Configuration
TTS_MODEL_NAME=ai4bharat/indic-parler-tts
TTS_DEVICE=auto

# Voice Service port
VOICE_SERVICE_PORT=8000

# ============== LLM SERVICE (Ollama) ==============

# Ollama serves both embeddings and LLM (OpenAI-compatible)
LLM_SERVICE_BASE_URL=http://host.docker.internal:11434/v1
LLM_MODEL=llama3.2:3b

# ============== CHROMADB ==============

# Disable telemetry
CHROMA_TELEMETRY=FALSE

# ============================================================
# NOTES
# ============================================================
#
# For Docker deployments on different platforms:
#
# macOS:
#   - Use host.docker.internal to access host services
#   - GPU services (STT/TTS) will use CPU mode in dev
#
# Windows:
#   - Use host.docker.internal for WSL2
#   - Ensure NVIDIA Container Toolkit is installed for GPU
#
# Linux:
#   - Use host.docker.internal or 172.17.0.1
#   - Add --network=host for full host network access
#
# GPU Requirements:
#   - NVIDIA GPU with CUDA 12.x support
#   - NVIDIA Container Toolkit installed
#   - nvidia-docker2 package
#
# Minimum Resources:
#   - 16GB RAM
#   - 50GB disk space (for models and data)
#   - GPU with 8GB+ VRAM (for STT/TTS)
#
# ============================================================
